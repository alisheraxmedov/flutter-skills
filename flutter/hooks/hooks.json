{
  "description": "Flutter plugin hooks: orchestrator nudge on session start (Flutter projects only) and non-blocking skill-usage logging. Safe, optional, and fully disableable — see hooks/README.md.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/flutter-session-start.sh",
            "args": [],
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-skill-usage.sh",
            "args": [],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
